# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# macOS cruft
.DS_Store

# Go / build caches
.cache/
.gocache/
gocache/
.gomodcache/
.gopath/
bin/
/containd
/ngfw-engine
/ngfw-mgmt
/smoketest

# MkDocs
site/
ui/public/docs/

# Node/Next.js
node_modules/
ui/.next/
ui/node_modules/
ui/.turbo/
ui/.vercel/
ui/out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data (docker-compose volumes)
data/

# Internal development files (kept locally, not published)
agents.md
linear-dashboard-cursor-rule.md
docs/tasks.md
docs/spec-archive/

# Editor/IDE
.idea/
.vscode/

# AI tools
.claude/
.cursor/
.cursorrules
.cursorignore
.aider*
.codeium/
.windsurf/
.copilot/
CLAUDE.md
