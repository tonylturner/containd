#!/usr/bin/env bash
# Convenience wrapper to build the smoke harness and run DPI + forwarding smoke.
# Set SMOKE_INCLUDE_DPI=0 to skip the live-DPI phase.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

export COMPOSE_FILE=${COMPOSE_FILE:-deploy/docker-compose.smoke.yml}
export BASE=${BASE:-http://localhost:18080/api/v1}
export TOKEN=${TOKEN:-devtoken}

if [[ "${SMOKE_INCLUDE_DPI:-1}" != "0" ]]; then
  bash ./scripts/smoke-dpi.sh
  SMOKE_SKIP_UP=1 SMOKE_BUILD=0 bash ./scripts/smoke-forward.sh
else
  bash ./scripts/smoke-forward.sh
fi
