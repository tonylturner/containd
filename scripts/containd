#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-up}"
shift || true

case "${cmd}" in
  up)
    # Starts in detached mode and prints connection info immediately after.
    # For local development, rebuild images so UI/API changes are reflected without needing
    # the user to remember `--build`.
    docker compose -f "$(dirname "$0")/../deploy/docker-compose.yml" up -d --build "$@"
    echo ""
    bash "$(dirname "$0")/containd-connect" containd || true
    ;;
  down)
    docker compose -f "$(dirname "$0")/../deploy/docker-compose.yml" down "$@"
    ;;
  logs)
    docker compose -f "$(dirname "$0")/../deploy/docker-compose.yml" logs -f "$@"
    ;;
  connect)
    bash "$(dirname "$0")/containd-connect" "${1:-containd}"
    ;;
  *)
    echo "Usage: bash scripts/containd <up|down|logs|connect> [args...]" >&2
    exit 2
    ;;
esac
