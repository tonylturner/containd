# syntax=docker/dockerfile:1
FROM golang:1.22-alpine AS builder

WORKDIR /src
COPY go.mod ./
COPY go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/ngfw-mgmt ./cmd/ngfw-mgmt

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/ngfw-mgmt /usr/bin/ngfw-mgmt
COPY ui/public /var/lib/ngfw/ui
EXPOSE 8080
ENTRYPOINT ["/usr/bin/ngfw-mgmt"]
