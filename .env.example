# containd docker compose environment
# Copy to `.env` and edit as needed.
#
# Notes:
# - Docker Compose automatically reads `.env` in this directory.
# - `.env` is ignored by git; `.env.example` is the committed template.
# - Change `CONTAIND_JWT_SECRET` for anything beyond local dev.

### Runtime mode
# Default is combined mgmt+engine. Set to "mgmt" or "engine" to split.
CONTAIND_MODE=all
CONTAIND_LAB_MODE=0

### Image
CONTAIND_IMAGE=ghcr.io/tonylturner/containd:latest

### Management listeners (inside container)
CONTAIND_MGMT_HTTP_ADDR=:8080
CONTAIND_MGMT_HTTPS_ADDR=:8443

### Published ports (host -> container)
CONTAIND_PUBLISH_HTTP_PORT=8080
CONTAIND_PUBLISH_HTTPS_PORT=8443
CONTAIND_PUBLISH_SSH_PORT=2222
# Optional: publish engine API to host (usually not needed in combined mode).
#CONTAIND_PUBLISH_ENGINE_PORT=8081

### Persistent DB paths (inside container; should be under /data)
CONTAIND_CONFIG_DB=/data/config.db
CONTAIND_AUDIT_DB=/data/audit.db
CONTAIND_USERS_DB=/data/users.db

### SSH
CONTAIND_SSH_ADDR=:2222
CONTAIND_SSH_AUTH_KEYS_DIR=/data/ssh/authorized_keys.d
CONTAIND_SSH_HOST_KEY=/data/ssh/host_key

# Optional: seed an initial admin SSH key (authorized_keys line).
# This helps production bootstrapping without leaving password auth enabled long-term.
#CONTAIND_SSH_BOOTSTRAP_ADMIN_KEY=ssh-ed25519 AAAA... user@host
CONTAIND_SSH_BOOTSTRAP_ADMIN_USER=containd

### Management <-> engine
# In combined mode, keep loopback/defaults. In split deployments, point ENGINE_URL at the engine host.
CONTAIND_ENGINE_URL=http://127.0.0.1:8081
CONTAIND_ENGINE_ADDR=:8081

### Dataplane knobs (engine)
CONTAIND_CAPTURE_IFACES=
# Starter lab mode enables nftables enforcement by default so container
# networks are segmented once you bind zones and commit policy.
# Set to 0 only for observe-only demos or troubleshooting.
CONTAIND_ENFORCE_ENABLED=1

### Starter lab topology (Docker-owned)
# Edit these to match your lab. The starter compose pins containd to .2 on each
# zone network and keeps WAN as the default-gateway interface.
# The bootstrap/quickstart scripts may rewrite these on first setup if the
# default 192.168.240.0/24-192.168.247.0/24 pool overlaps with existing Docker
# networks on your machine.
CONTAIND_WAN_SUBNET=192.168.240.0/24
CONTAIND_WAN_IP=192.168.240.2
CONTAIND_DMZ_SUBNET=192.168.241.0/24
CONTAIND_DMZ_IP=192.168.241.2
CONTAIND_LAN1_SUBNET=192.168.242.0/24
CONTAIND_LAN1_IP=192.168.242.2
CONTAIND_LAN2_SUBNET=192.168.243.0/24
CONTAIND_LAN2_IP=192.168.243.2
CONTAIND_LAN3_SUBNET=192.168.244.0/24
CONTAIND_LAN3_IP=192.168.244.2
CONTAIND_LAN4_SUBNET=192.168.245.0/24
CONTAIND_LAN4_IP=192.168.245.2
CONTAIND_LAN5_SUBNET=192.168.246.0/24
CONTAIND_LAN5_IP=192.168.246.2
CONTAIND_LAN6_SUBNET=192.168.247.0/24
CONTAIND_LAN6_IP=192.168.247.2

# Optional: if you customize the starter subnets, keep auto-assign hints aligned.
#CONTAIND_AUTO_WAN_SUBNET=192.168.240.0/24
#CONTAIND_AUTO_DMZ_SUBNET=192.168.241.0/24
#CONTAIND_AUTO_LAN1_SUBNET=192.168.242.0/24
#CONTAIND_AUTO_LAN2_SUBNET=192.168.243.0/24
#CONTAIND_AUTO_LAN3_SUBNET=192.168.244.0/24
#CONTAIND_AUTO_LAN4_SUBNET=192.168.245.0/24
#CONTAIND_AUTO_LAN5_SUBNET=192.168.246.0/24
#CONTAIND_AUTO_LAN6_SUBNET=192.168.247.0/24

### Auth
# CHANGE THIS for real deployments.
# Starter scripts generate this automatically when it is blank.
CONTAIND_JWT_SECRET=

# Default admin user provisioned on fresh installs (when users DB is empty).
# Defaults to containd/containd.
#CONTAIND_DEFAULT_ADMIN_USERNAME=containd
#CONTAIND_DEFAULT_ADMIN_PASSWORD=containd

# Force cookie Secure flag even behind a TLS-terminating proxy (set to 1 when using HTTPS).
CONTAIND_COOKIE_SECURE=0

# Comma-separated CIDRs/IPs for reverse proxies you explicitly trust (optional).
# Example: CONTAIND_TRUSTED_PROXIES=127.0.0.1,::1,10.0.0.0/8
CONTAIND_TRUSTED_PROXIES=

# Optional comma-separated browser origins allowed to embed or call the UI/API
# cross-origin. Cookie-authenticated browser writes from other origins are
# denied unless the origin appears here.
# Example: CONTAIND_ALLOWED_ORIGINS=https://portal.example.com,https://lab.local
CONTAIND_ALLOWED_ORIGINS=
